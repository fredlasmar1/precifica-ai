# OpenAI
OPENAI_API_KEY=sk-...

# Google Places
GOOGLE_PLACES_API_KEY=AIza...

# ScraperAPI (opcional) — para contornar Cloudflare do ZAP Imóveis
# Crie conta em https://www.scraperapi.com/ (free tier: 1000 requisições/mês)
# Sem essa chave, o sistema usa apenas dados de fallback (que já são bons).
SCRAPER_API_KEY=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=nome-da-instancia

# Servidor
PORT=3000
NODE_ENV=production
