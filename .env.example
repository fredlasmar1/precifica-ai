# OpenAI
OPENAI_API_KEY=sk-...

# Google Places
GOOGLE_PLACES_API_KEY=AIza...

# Perplexity API — pesquisa preços REAIS na internet
# Crie em https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# ScraperAPI (opcional) — para contornar Cloudflare do ZAP Imóveis
SCRAPER_API_KEY=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-aqui
EVOLUTION_INSTANCE=nome-da-instancia

# Servidor
PORT=3000
NODE_ENV=production
